NVIDIA_API_KEY=
NVIDIA_MODEL=deepseek-ai/deepseek-v3.1
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_THINKING_MODE=true
LLM_TEMPERATURE=0.2
LLM_TOP_P=0.7
LLM_MAX_TOKENS=256
LLM_TIMEOUT_SECONDS=8
LLM_MAX_RETRIES=1
CHAT_SESSION_MAX_MESSAGES=10
CHAT_SESSION_TTL_SECONDS=86400
CHAT_SUMMARY_CHAR_LIMIT=600
